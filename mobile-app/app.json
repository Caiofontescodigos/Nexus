{
  "expo": {
    "name": "Nexus Tasks",
    "slug": "nexus-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f0f13"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nexus.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f0f13"
      },
      "package": "com.nexus.mobile"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
